mom_hs == 0 & mom_work <= 2 ~ "Low advantage",
mom_hs == 0 & mom_work >  2 ~ "Mixed advantage",
mom_hs == 1 & mom_work <= 2 ~ "Mixed advantage",
mom_hs == 1 & mom_work >  2 ~ "High advantage",
TRUE ~ NA_character_
),
iq_group = case_when(
mom_iq <= quantile(mom_iq, 0.33, na.rm = TRUE) ~ "Lower IQ Group",
mom_iq <= quantile(mom_iq, 0.67, na.rm = TRUE) ~ "Middle IQ Group",
TRUE ~ "Higher IQ Group"
),
family_advantage = factor(family_advantage,
levels = c("Low advantage","Mixed advantage","High advantage")),
iq_group = factor(iq_group,
levels = c("Lower IQ Group","Middle IQ Group","Higher IQ Group"))
) %>%
filter(!is.na(family_advantage), !is.na(iq_group)) %>%
ggplot(aes(x = family_advantage, y = kid_score, fill = family_advantage)) +
geom_violin(trim = FALSE, alpha = 0.6, width = 0.8, color = NA) +
stat_summary(fun = median, geom = "crossbar", width = 0.5, color = "black", fatten = 1) +
geom_jitter(width = 0.10, height = 0, alpha = 0.25, size = 1.2, color = "black", show.legend = FALSE) +
facet_wrap(~ iq_group, nrow = 1) +
scale_fill_brewer(palette = "Set2", guide = "none") +
scale_x_discrete(labels = c("Low advantage"="Low","Mixed advantage"="Mixed","High advantage"="High")) +
labs(
title = "Child Scores by Family Background and Maternal IQ",
subtitle = "Higher family advantage leads to higher scores even within the same IQ groups.",
x = "Family Advantage Level",
y = "Child's Test Score",
caption = "Data: NLSY (Gelman & Hill, 2007)"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "none",
plot.title = element_text(face = "bold", size = 16),
strip.text = element_text(face = "bold", size = 11),
panel.grid.major.x = element_blank()
)
print(plot_iq)
plot_merit <- kidiq %>%
mutate(
mom_hs_label = factor(mom_hs, labels = c("No HS diploma", "HS diploma")),
ability_level = case_when(
mom_iq <= quantile(mom_iq, 0.25, na.rm = TRUE) ~ "Low ability",
mom_iq <= quantile(mom_iq, 0.75, na.rm = TRUE) ~ "Medium ability",
TRUE ~ "High ability"
),
outcome_level = case_when(
kid_score <= quantile(kid_score, 0.25, na.rm = TRUE) ~ "Low outcome",
kid_score <= quantile(kid_score, 0.75, na.rm = TRUE) ~ "Medium outcome",
TRUE ~ "High outcome"
),
surprising_case = case_when(
ability_level == "High ability" & outcome_level == "Low outcome" ~
"High ability, low outcome",
ability_level == "Low ability"  & outcome_level == "High outcome" ~
"Low ability, high outcome",
TRUE ~ NA_character_
)
)
ggplot(plot_merit, aes(mom_iq, kid_score)) +
stat_bin2d(bins = 24) +
scale_fill_viridis_c(name = "Cases", option = "C", direction = -1) +
geom_smooth(method = "lm", se = FALSE, linetype = "dashed",
color = "white", linewidth = 1) +
geom_point(
data = dplyr::filter(plot_merit, !is.na(surprising_case)),
aes(color = surprising_case),
size = 2.6
) +
scale_color_manual(
values = c("High ability, low outcome" = "#E69F00",
"Low ability, high outcome" = "#56B4E9"),
name = "Surprising cases"
) +
facet_wrap(~ mom_hs_label, nrow = 1) +
coord_cartesian(xlim = c(75, 135), ylim = c(40, 120)) +
labs(
title = "Is Merit Enough?",
subtitle = "Tiles show where most cases sit; dashed lines show the IQ→score trend.
Highlighted dots mark exceptions where merit alone didn’t predict outcomes.",
x = "Mother’s IQ (ability proxy)",
y = "Child’s test score",
caption = "Data: NLSY (Gelman & Hill, 2007)"
) +
theme_minimal(base_size = 12) +
theme(
legend.position = "bottom",
legend.title = element_text(face = "bold"),
strip.text = element_text(face = "bold"),
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
plot.margin = margin(10, 20, 10, 20)
)
rmarkdown::render_site()
distill::create_post("text-analysis-concession-speeches")
rownames(coef(nb))
knitr::opts_chunk$set(echo = FALSE, message = FALSE, warning = FALSE)
library(stringr)
library(quanteda)
library(readtext)
library(quanteda.textmodels)
library(caret)
library(ggplot2)
library(dplyr)
speeches <- readtext("Concession Speeches/*.txt")
speeches_corpus <- corpus(speeches)
nms <- names(speeches_corpus)
speeches_corpus$Year  <- as.numeric(gsub('[^[:digit:]]', '', nms))
speeches_corpus$Party <- str_sub(nms, start = -5, -5)
speeches_corpus$Name  <- str_sub(nms, end = -12)
speeches_para <- corpus_reshape(speeches_corpus, to = "paragraphs", use_docvars = TRUE)
toks <- tokens(speeches_para, remove_punct = TRUE, remove_symbols = TRUE,
remove_numbers = TRUE, split_hyphens = TRUE)
toks <- tokens_wordstem(toks)
toks <- tokens_remove(toks, pattern = c("applpaus", "applause"))
toks <- tokens_select(toks, c("*st", "*th", "*rd"), selection = "remove")
dfm_all  <- dfm(toks) |> dfm_remove(stopwords("english")) |> dfm_trim(min_termfreq = 3)
dfm_bool <- dfm_weight(dfm_all, scheme = "boolean")
set.seed(2025)
train_idx <- sample(1:ndoc(dfm_bool), size = 0.8 * ndoc(dfm_bool))
test_idx  <- setdiff(1:ndoc(dfm_bool), train_idx)
dfm_train <- dfm_bool[train_idx, ]
dfm_test  <- dfm_bool[test_idx, ]
y_train   <- docvars(dfm_train, "Party")
y_test    <- docvars(dfm_test, "Party")
nb        <- textmodel_nb(dfm_train, y_train, distribution = "Bernoulli")
predicted <- predict(nb, newdata = dfm_match(dfm_test, featnames(dfm_train)))
tab       <- table(predicted, y_test)
cfm       <- confusionMatrix(tab, mode = "everything", positive = "D")
as.data.frame(tab) |>
rename(Predicted = predicted, Actual = y_test) |>
ggplot(aes(x = Actual, y = Predicted, fill = Freq)) +
geom_tile(colour = "white", linewidth = 1.5) +
geom_text(aes(label = Freq), size = 9, fontface = "bold", colour = "white") +
scale_fill_gradient(low = "#9ecae1", high = "#2166ac") +
labs(
title    = "How Well Does the Model Classify Party?",
subtitle = "Bernoulli Naive Bayes — predicted vs actual party label",
x = "Actual Party", y = "Predicted Party",
caption  = "D = Democrat, R = Republican. Paragraphs from 19 concession speeches (1896–2016)."
) +
theme_minimal(base_size = 13) +
theme(plot.title = element_text(face = "bold"), panel.grid = element_blank())
cat("Accuracy:  ", round(cfm$overall["Accuracy"], 3), "\n")
cat("Precision: ", round(cfm$byClass["Precision"], 3), "\n")
cat("Recall:    ", round(cfm$byClass["Recall"], 3), "\n")
cat("F1:        ", round(cfm$byClass["F1"], 3), "\n")
log_diff <- coef(nb)["D", ] - coef(nb)["R", ]
rownames(coef(nb))
knitr::opts_chunk$set(echo = FALSE, message = FALSE, warning = FALSE)
library(stringr)
library(quanteda)
library(readtext)
library(quanteda.textmodels)
library(caret)
library(ggplot2)
library(dplyr)
speeches <- readtext("Concession Speeches/*.txt")
speeches_corpus <- corpus(speeches)
nms <- names(speeches_corpus)
speeches_corpus$Year  <- as.numeric(gsub('[^[:digit:]]', '', nms))
speeches_corpus$Party <- str_sub(nms, start = -5, -5)
speeches_corpus$Name  <- str_sub(nms, end = -12)
speeches_para <- corpus_reshape(speeches_corpus, to = "paragraphs", use_docvars = TRUE)
toks <- tokens(speeches_para, remove_punct = TRUE, remove_symbols = TRUE,
remove_numbers = TRUE, split_hyphens = TRUE)
toks <- tokens_wordstem(toks)
toks <- tokens_remove(toks, pattern = c("applpaus", "applause"))
toks <- tokens_select(toks, c("*st", "*th", "*rd"), selection = "remove")
dfm_all  <- dfm(toks) |> dfm_remove(stopwords("english")) |> dfm_trim(min_termfreq = 3)
dfm_bool <- dfm_weight(dfm_all, scheme = "boolean")
set.seed(2025)
train_idx <- sample(1:ndoc(dfm_bool), size = 0.8 * ndoc(dfm_bool))
test_idx  <- setdiff(1:ndoc(dfm_bool), train_idx)
dfm_train <- dfm_bool[train_idx, ]
dfm_test  <- dfm_bool[test_idx, ]
y_train   <- docvars(dfm_train, "Party")
y_test    <- docvars(dfm_test, "Party")
nb        <- textmodel_nb(dfm_train, y_train, distribution = "Bernoulli")
predicted <- predict(nb, newdata = dfm_match(dfm_test, featnames(dfm_train)))
tab       <- table(predicted, y_test)
cfm       <- confusionMatrix(tab, mode = "everything", positive = "D")
as.data.frame(tab) |>
rename(Predicted = predicted, Actual = y_test) |>
ggplot(aes(x = Actual, y = Predicted, fill = Freq)) +
geom_tile(colour = "white", linewidth = 1.5) +
geom_text(aes(label = Freq), size = 9, fontface = "bold", colour = "white") +
scale_fill_gradient(low = "#9ecae1", high = "#2166ac") +
labs(
title    = "How Well Does the Model Classify Party?",
subtitle = "Bernoulli Naive Bayes — predicted vs actual party label",
x = "Actual Party", y = "Predicted Party",
caption  = "D = Democrat, R = Republican. Paragraphs from 19 concession speeches (1896–2016)."
) +
theme_minimal(base_size = 13) +
theme(plot.title = element_text(face = "bold"), panel.grid = element_blank())
cat("Accuracy:  ", round(cfm$overall["Accuracy"], 3), "\n")
cat("Precision: ", round(cfm$byClass["Precision"], 3), "\n")
cat("Recall:    ", round(cfm$byClass["Recall"], 3), "\n")
cat("F1:        ", round(cfm$byClass["F1"], 3), "\n")
log_diff <- coef(nb)[, "D"] - coef(nb)[, "R"]
rbind(
data.frame(word = names(sort(log_diff, decreasing = TRUE)[1:12]),
score = as.numeric(sort(log_diff, decreasing = TRUE)[1:12]),
party = "Democrat"),
data.frame(word = names(sort(log_diff)[1:12]),
score = abs(as.numeric(sort(log_diff)[1:12])),
party = "Republican")
) |>
ggplot(aes(x = reorder(word, score), y = score, fill = party)) +
geom_col(show.legend = FALSE, width = 0.7) +
facet_wrap(~ party, scales = "free_y") +
coord_flip() +
scale_fill_manual(values = c("Democrat" = "#2166ac", "Republican" = "#d6604d")) +
labs(
title    = "The Words That Reveal Party Identity",
subtitle = "Largest difference in Naive Bayes feature scores between parties",
x = NULL, y = "Score difference",
caption  = "Stemmed tokens. Bernoulli Naive Bayes trained on paragraph-level features."
) +
theme_minimal(base_size = 13) +
theme(plot.title = element_text(face = "bold"), strip.text = element_text(face = "bold"),
panel.grid.major.x = element_blank())
knitr::opts_chunk$set(echo = FALSE, message = FALSE, warning = FALSE)
